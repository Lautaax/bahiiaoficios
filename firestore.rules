rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isClient() {
       // Verificación simple basada en el documento del usuario (seguridad media)
       // Idealmente usar Custom Claims
       return isAuthenticated() && 
              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'cliente';
    }

    match /usuarios/{userId} {
      allow read: if true; // Cualquiera puede ver perfiles
      allow write: if isOwner(userId); // Solo el dueño edita su perfil
      
      // El dueño puede editar, PERO NO puede tocar campos sensibles del perfil profesional
      // Esta regla es redundante con la de arriba si 'isOwner' ya permite write, pero la mantenemos para validación de campos
      // Sin embargo, la regla de arriba 'allow write' sobrescribe restricciones más específicas si devuelve true.
      // Para aplicar la restricción de campos, debemos refinar la regla de update.
    }
    
    // Reglas refinadas para usuarios (reemplazando el bloque anterior para mayor claridad y seguridad)
    // match /usuarios/{userId} {
    //   allow read: if true;
    //   allow create: if isOwner(userId);
    //   allow update: if isOwner(userId) 
    //                 && (!request.resource.data.diff(resource.data).affectedKeys()
    //                     .hasAny(['profesionalInfo.isVip', 'profesionalInfo.ratingAvg', 'profesionalInfo.reviewCount', 'profesionalInfo.vipExpiration']));
    // }
    // Mantenemos la lógica existente que ya era segura, pero ajustamos comentarios.

    match /resenas/{resenaId} {
      allow read: if true;
      
      // Solo clientes autenticados pueden opinar
      allow create: if isAuthenticated() 
                    && request.resource.data.clienteId == request.auth.uid
                    && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "cliente"
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.profesionalId is string;
                    
      allow update, delete: if false;
    }
  }
}
